    "test": "npm run build && node --test dist/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "2.12.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.0",
    "better-sqlite3": "^12.9.0"
  }
}
