PORT=8787
HOST=127.0.0.1
OPENAI_API_KEY=sk-local-development-key
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# Optional global override for every /ai request. Leave unset to honor the model selected in Warp.
# OPENAI_MODEL=Qwen/Qwen3.6-27B-FP8
LOCAL_MODEL_ALIASES={"auto-efficient":"Qwen/Qwen3.6-27B-FP8","auto-coding":"Qwen/Qwen3.6-27B-FP8"}
# Optional fallback if OPENAI_BASE_URL/models is unavailable.
LOCAL_MODEL_LIST=Qwen/Qwen3.6-27B-FP8
LOG_LEVEL=info
LOCAL_ENABLE_TOOLS=true
# Optional. Use when OPENAI_BASE_URL/models does not expose context length metadata.
# Accepts a single token count or a JSON object keyed by provider model ID.
# LOCAL_MODEL_CONTEXT_TOKENS={"Qwen/Qwen3.6-27B-FP8":262144,"default":131072}
# Stores local GraphQL integration config and /ai conversation transcripts.
LOCAL_GRAPHQL_DB_PATH=./local-graphql.sqlite

# Optional. Sent as the first chat message before Warp's user request.
LOCAL_MULTI_AGENT_SYSTEM_PROMPT=You are running as a local Warp-compatible agent endpoint.
